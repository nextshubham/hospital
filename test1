//httpRetry.ts
import axios, {
  AxiosError,
  AxiosResponse,
  InternalAxiosRequestConfig,
} from 'axios';
import config from '../config/env';
import httpsAgent from '../constants/httpAgent';
import logger from '../utils/logger';
import { getAprimoAccessToken } from './aprimoTokenService';

const HTTP_RETRY_COUNT = 3;
const HTTP_RETRY_DELAY_INCREMENT_MS = 500;

type RetriableRequestConfig = InternalAxiosRequestConfig & {
  retryAttempt?: number;
};

const delay = (delayMs: number): Promise<void> =>
  new Promise(resolve => {
    setTimeout(resolve, delayMs);
  });

const getRetryDelay = (retryAttempt: number): number =>
  retryAttempt * HTTP_RETRY_DELAY_INCREMENT_MS;

const isRetryableHttpError = (error: AxiosError): boolean => {
  const status = error.response?.status;

  if (status === undefined) {
    return true;
  }

  return status === 408 || status === 429 || status >= 500;
};

const httpClient = axios.create({
  baseURL: config.APRIMO_BASE_URL,
  timeout: 30000,
  httpsAgent,
});

httpClient.interceptors.request.use(
  async (
    requestConfig: InternalAxiosRequestConfig
  ): Promise<InternalAxiosRequestConfig> => {
    const token = await getAprimoAccessToken();

    return {
      ...requestConfig,
      headers: {
        ...requestConfig.headers,
        Accept: 'application/json',
        Authorization: `Bearer ${token}`,
      } as InternalAxiosRequestConfig['headers'],
    };
  },
  (error: unknown): Promise<never> => {
    if (error instanceof Error) {
      return Promise.reject(error);
    }

    return Promise.reject(new Error(String(error)));
  }
);

httpClient.interceptors.response.use(
  (response: AxiosResponse): AxiosResponse => response,
  async (error: unknown): Promise<AxiosResponse> => {
    if (!axios.isAxiosError(error) || error.config === undefined) {
      if (error instanceof Error) {
        return Promise.reject(error);
      }

      return Promise.reject(new Error(String(error)));
    }

    const requestConfig = error.config as RetriableRequestConfig;

    requestConfig.retryAttempt = requestConfig.retryAttempt ?? 0;

    if (
      requestConfig.retryAttempt >= HTTP_RETRY_COUNT ||
      !isRetryableHttpError(error)
    ) {
      return Promise.reject(error);
    }

    requestConfig.retryAttempt += 1;

    const delayMs = getRetryDelay(requestConfig.retryAttempt);

    logger.warn({
      msg: 'Retrying Aprimo HTTP request',
      options: {
        retryAttempt: requestConfig.retryAttempt,
        delayMs,
        status: error.response?.status,
        url: requestConfig.url,
        method: requestConfig.method,
      },
    });

    await delay(delayMs);

    return httpClient.request(requestConfig);
  }
);

export default httpClient;
