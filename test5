7import express, { ErrorRequestHandler } from 'express';
import request from 'supertest';
import WebhookController from '../../controllers/WebhookController';
import { processAssetExpiryWebhook } from '../../services/webhookService';

jest.mock('../../services/webhookService');

const mockedProcessAssetExpiryWebhook =
  processAssetExpiryWebhook as jest.MockedFunction<
    typeof processAssetExpiryWebhook
  >;

describe('WebhookController', () => {
  const createApp = () => {
    const app = express();

    app.use(express.json());

    app.post(
      '/api/v1/webhook/asset-expiry',
      WebhookController.assetExpiry
    );

    const errorHandler: ErrorRequestHandler = (error, _req, res, _next) => {
      res.status(500).json({
        message: error.message,
      });
    };

    app.use(errorHandler);

    return app;
  };

  beforeEach(() => {
    jest.clearAllMocks();
  });

  it('should process asset expiry webhook successfully', async () => {
    const app = createApp();

    const payload = {
      environment: 'dev',
      recordId: 'test-record-id',
      contentType: 'Asset',
      triggerType: 'update',
      calculatedExpirationDate: '2026-12-31',
    };

    mockedProcessAssetExpiryWebhook.mockResolvedValue({
      message: 'processed',
    });

    const response = await request(app)
      .post('/api/v1/webhook/asset-expiry')
      .send(payload);

    expect(response.status).toBe(200);
    expect(mockedProcessAssetExpiryWebhook).toHaveBeenCalledWith(payload);
    expect(response.body).toEqual({
      status: 200,
      message: 'Asset expiry webhook processed successfully',
      data: {
        message: 'processed',
      },
    });
  });

  it('should call error middleware when service fails', async () => {
    const app = createApp();

    mockedProcessAssetExpiryWebhook.mockRejectedValue(
      new Error('Webhook processing failed')
    );

    const response = await request(app)
      .post('/api/v1/webhook/asset-expiry')
      .send({
        recordId: 'test-record-id',
        contentType: 'Asset',
      });

    expect(response.status).toBe(500);
    expect(response.body).toEqual({
      message: 'Webhook processing failed',
    });
  });
});
