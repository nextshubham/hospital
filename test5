export {123};

const mockRequestInterceptorUse = jest.fn();
const mockResponseInterceptorUse = jest.fn();

const mockAxiosInstance = {
  interceptors: {
    request: {
      use: mockRequestInterceptorUse,
    },
    response: {
      use: mockResponseInterceptorUse,
    },
  },
  request: jest.fn(),
  get: jest.fn(),
  put: jest.fn(),
  post: jest.fn(),
};

const mockAxiosCreate = jest.fn(() => mockAxiosInstance);
const mockAxiosIsAxiosError = jest.fn();
const mockGetAprimoAccessToken = jest.fn();
const mockLoggerWarn = jest.fn();

const mockDelay = jest.fn().mockResolvedValue(undefined);
const mockGetRetryDelay = jest.fn((retryAttempt: number) => retryAttempt * 500);
const mockIsRetryableHttpError = jest.fn();

jest.mock('axios', () => ({
  __esModule: true,
  default: {
    create: mockAxiosCreate,
    isAxiosError: mockAxiosIsAxiosError,
  },
  create: mockAxiosCreate,
  isAxiosError: mockAxiosIsAxiosError,
}));

jest.mock('../../config/env', () => ({
  __esModule: true,
  default: {
    APRIMO_BASE_URL: 'https://training3.dam.aprimo.com',
  },
}));

jest.mock('../../utils/logger', () => ({
  __esModule: true,
  default: {
    warn: mockLoggerWarn,
    error: jest.fn(),
    info: jest.fn(),
    debug: jest.fn(),
    trace: jest.fn(),
  },
}));

jest.mock('../../utils/httpRetry', () => ({
  HTTP_RETRY_COUNT: 3,
  delay: mockDelay,
  getRetryDelay: mockGetRetryDelay,
  isRetryableHttpError: mockIsRetryableHttpError,
}));

jest.mock('../../services/aprimoTokenService', () => ({
  getAprimoAccessToken: mockGetAprimoAccessToken,
}));

describe('httpClient', () => {
  beforeEach(() => {
    jest.resetModules();
    jest.clearAllMocks();

    mockAxiosCreate.mockReturnValue(mockAxiosInstance);
    mockDelay.mockResolvedValue(undefined);
    mockGetRetryDelay.mockImplementation(
      (retryAttempt: number) => retryAttempt * 500
    );
  });

  it('should create axios instance with Aprimo base URL, timeout and https agent', async () => {
    const httpClient = await import('../../services/httpClient');

    expect(mockAxiosCreate).toHaveBeenCalledTimes(1);

    expect(mockAxiosCreate).toHaveBeenCalledWith(
      expect.objectContaining({
        baseURL: 'https://training3.dam.aprimo.com',
        timeout: 30000,
        httpsAgent: expect.any(Object),
      })
    );

    expect(httpClient.default).toBe(mockAxiosInstance);
  });

  it('should register request and response interceptors', async () => {
    await import('../../services/httpClient');

    expect(mockRequestInterceptorUse).toHaveBeenCalledTimes(1);
    expect(mockResponseInterceptorUse).toHaveBeenCalledTimes(1);

    expect(mockRequestInterceptorUse).toHaveBeenCalledWith(
      expect.any(Function),
      expect.any(Function)
    );

    expect(mockResponseInterceptorUse).toHaveBeenCalledWith(
      expect.any(Function),
      expect.any(Function)
    );
  });

  it('should add Authorization and Accept headers in request interceptor', async () => {
    await import('../../services/httpClient');

    mockGetAprimoAccessToken.mockResolvedValue('test-access-token');

    const requestSuccessHandler = mockRequestInterceptorUse.mock.calls[0][0];

    const requestConfig = {
      headers: {
        ExistingHeader: 'existing-value',
      },
    };

    const result = await requestSuccessHandler(requestConfig);

    expect(mockGetAprimoAccessToken).toHaveBeenCalledTimes(1);

    expect(result).toEqual(
      expect.objectContaining({
        headers: expect.objectContaining({
          ExistingHeader: 'existing-value',
          Accept: 'application/json',
          Authorization: 'Bearer test-access-token',
        }),
      })
    );
  });

  it('should add Authorization and Accept headers when request headers are missing', async () => {
    await import('../../services/httpClient');

    mockGetAprimoAccessToken.mockResolvedValue('test-access-token');

    const requestSuccessHandler = mockRequestInterceptorUse.mock.calls[0][0];

    const requestConfig = {};

    const result = await requestSuccessHandler(requestConfig);

    expect(result).toEqual(
      expect.objectContaining({
        headers: expect.objectContaining({
          Accept: 'application/json',
          Authorization: 'Bearer test-access-token',
        }),
      })
    );
  });

  it('should reject request interceptor error when error is Error instance', async () => {
    await import('../../services/httpClient');

    const requestErrorHandler = mockRequestInterceptorUse.mock.calls[0][1];

    const error = new Error('Request interceptor failed');

    await expect(requestErrorHandler(error)).rejects.toThrow(
      'Request interceptor failed'
    );
  });

  it('should convert non Error request rejection reason to Error', async () => {
    await import('../../services/httpClient');

    const requestErrorHandler = mockRequestInterceptorUse.mock.calls[0][1];

    await expect(requestErrorHandler('plain request error')).rejects.toThrow(
      'plain request error'
    );
  });

  it('should return response from response success interceptor', async () => {
    await import('../../services/httpClient');

    const responseSuccessHandler = mockResponseInterceptorUse.mock.calls[0][0];

    const response = {
      data: {
        id: 'test-record-id',
      },
    };

    const result = responseSuccessHandler(response);

    expect(result).toBe(response);
  });

  it('should reject non Axios response error when error is Error instance', async () => {
    await import('../../services/httpClient');

    const responseErrorHandler = mockResponseInterceptorUse.mock.calls[0][1];

    mockAxiosIsAxiosError.mockReturnValue(false);

    const error = new Error('Response interceptor failed');

    await expect(responseErrorHandler(error)).rejects.toThrow(
      'Response interceptor failed'
    );

    expect(mockDelay).not.toHaveBeenCalled();
    expect(mockAxiosInstance.request).not.toHaveBeenCalled();
  });

  it('should convert non Error response rejection reason to Error', async () => {
    await import('../../services/httpClient');

    const responseErrorHandler = mockResponseInterceptorUse.mock.calls[0][1];

    mockAxiosIsAxiosError.mockReturnValue(false);

    await expect(responseErrorHandler('plain response error')).rejects.toThrow(
      'plain response error'
    );

    expect(mockDelay).not.toHaveBeenCalled();
    expect(mockAxiosInstance.request).not.toHaveBeenCalled();
  });

  it('should reject Axios error when config is missing', async () => {
    await import('../../services/httpClient');

    const responseErrorHandler = mockResponseInterceptorUse.mock.calls[0][1];

    const error = {
      response: {
        status: 500,
      },
    };

    mockAxiosIsAxiosError.mockReturnValue(true);

    await expect(responseErrorHandler(error)).rejects.toThrow(
      '[object Object]'
    );

    expect(mockDelay).not.toHaveBeenCalled();
    expect(mockAxiosInstance.request).not.toHaveBeenCalled();
  });

  it('should retry retryable Aprimo HTTP request', async () => {
    await import('../../services/httpClient');

    const responseErrorHandler = mockResponseInterceptorUse.mock.calls[0][1];

    const requestConfig = {
      url: '/api/core/record/fcfa9e67eb034146819fb46d004b1262',
      method: 'get',
      headers: {},
    };

    const error = {
      response: {
        status: 500,
      },
      config: requestConfig,
    };

    const retryResponse = {
      data: {
        id: 'record-id',
      },
    };

    mockAxiosIsAxiosError.mockReturnValue(true);
    mockIsRetryableHttpError.mockReturnValue(true);
    mockAxiosInstance.request.mockResolvedValue(retryResponse);

    const result = await responseErrorHandler(error);

    expect(result).toBe(retryResponse);

    expect(requestConfig).toEqual(
      expect.objectContaining({
        retryAttempt: 1,
      })
    );

    expect(mockGetRetryDelay).toHaveBeenCalledWith(1);
    expect(mockDelay).toHaveBeenCalledWith(500);

    expect(mockLoggerWarn).toHaveBeenCalledWith({
      msg: 'Retrying Aprimo HTTP request',
      options: {
        retryAttempt: 1,
        delayMs: 500,
        status: 500,
        url: '/api/core/record/fcfa9e67eb034146819fb46d004b1262',
        method: 'get',
      },
    });

    expect(mockAxiosInstance.request).toHaveBeenCalledWith(
      expect.objectContaining({
        url: '/api/core/record/fcfa9e67eb034146819fb46d004b1262',
        method: 'get',
        retryAttempt: 1,
      })
    );
  });

  it('should reject Axios error when retry count is already exhausted', async () => {
    await import('../../services/httpClient');

    const responseErrorHandler = mockResponseInterceptorUse.mock.calls[0][1];

    const error = {
      response: {
        status: 500,
      },
      config: {
        url: '/api/core/record/fcfa9e67eb034146819fb46d004b1262',
        method: 'get',
        retryAttempt: 3,
      },
    };

    mockAxiosIsAxiosError.mockReturnValue(true);
    mockIsRetryableHttpError.mockReturnValue(true);

    await expect(responseErrorHandler(error)).rejects.toBe(error);

    expect(mockDelay).not.toHaveBeenCalled();
    expect(mockAxiosInstance.request).not.toHaveBeenCalled();
  });

  it('should reject Axios error when error is not retryable', async () => {
    await import('../../services/httpClient');

    const responseErrorHandler = mockResponseInterceptorUse.mock.calls[0][1];

    const error = {
      response: {
        status: 400,
      },
      config: {
        url: '/api/core/record/fcfa9e67eb034146819fb46d004b1262',
        method: 'get',
      },
    };

    mockAxiosIsAxiosError.mockReturnValue(true);
    mockIsRetryableHttpError.mockReturnValue(false);

    await expect(responseErrorHandler(error)).rejects.toBe(error);

    expect(mockDelay).not.toHaveBeenCalled();
    expect(mockAxiosInstance.request).not.toHaveBeenCalled();
  });

  it('should increase retryAttempt when retryAttempt already exists', async () => {
    await import('../../services/httpClient');

    const responseErrorHandler = mockResponseInterceptorUse.mock.calls[0][1];

    const requestConfig = {
      url: '/api/core/record/fcfa9e67eb034146819fb46d004b1262',
      method: 'put',
      retryAttempt: 1,
    };

    const error = {
      response: {
        status: 503,
      },
      config: requestConfig,
    };

    const retryResponse = {
      data: {
        updated: true,
      },
    };

    mockAxiosIsAxiosError.mockReturnValue(true);
    mockIsRetryableHttpError.mockReturnValue(true);
    mockAxiosInstance.request.mockResolvedValue(retryResponse);

    const result = await responseErrorHandler(error);

    expect(result).toBe(retryResponse);

    expect(requestConfig.retryAttempt).toBe(2);
    expect(mockGetRetryDelay).toHaveBeenCalledWith(2);
    expect(mockDelay).toHaveBeenCalledWith(1000);

    expect(mockAxiosInstance.request).toHaveBeenCalledWith(
      expect.objectContaining({
        method: 'put',
        retryAttempt: 2,
      })
    );
  });
});
