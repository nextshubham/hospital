import * as http from 'http';

const PORT = 4010;

let aprimoApiAttemptCount = 0;

process.env.APRIMO_BASE_URL = `http://localhost:${PORT}`;
process.env.APRIMO_TOKEN_URL = `http://localhost:${PORT}/oauth/token`;
process.env.APRIMO_CLIENT_ID = 'local-test-client-id';
process.env.APRIMO_CLIENT_SECRET = 'local-test-client-secret';
process.env.APRIMO_SCOPE = 'local-test-scope';

const sendJsonResponse = (
  response: http.ServerResponse,
  statusCode: number,
  data: unknown
): void => {
  response.writeHead(statusCode, {
    'Content-Type': 'application/json',
  });

  response.end(JSON.stringify(data));
};

const server = http.createServer(
  (request: http.IncomingMessage, response: http.ServerResponse): void => {
    if (request.method === 'POST' && request.url === '/oauth/token') {
      console.log('Token API called');

      sendJsonResponse(response, 200, {
        access_token: 'local-test-access-token',
        expires_in: 3600,
        token_type: 'Bearer',
      });

      return;
    }

    if (
      request.method === 'GET' &&
      request.url === '/api/core/record/retry-test'
    ) {
      aprimoApiAttemptCount += 1;

      console.log(`Aprimo API attempt number: ${aprimoApiAttemptCount}`);

      if (aprimoApiAttemptCount < 3) {
        sendJsonResponse(response, 500, {
          message: 'Temporary server error from local test API',
        });

        return;
      }

      sendJsonResponse(response, 200, {
        id: 'retry-test',
        message: 'API call successful after retry',
        totalAttempts: aprimoApiAttemptCount,
      });

      return;
    }

    sendJsonResponse(response, 404, {
      message: 'Route not found in local test API',
      method: request.method,
      url: request.url,
    });
  }
);

const runRetryApiTest = async (): Promise<void> => {
  server.listen(PORT, async () => {
    console.log(`Local test API started on http://localhost:${PORT}`);
    console.log('Importing httpClient after setting local test config');

    try {
      const { default: httpClient } = await import('./services/httpClient');

      const response = await httpClient.get('/api/core/record/retry-test');

      console.log('Final response:', response.data);
      console.log('Retry API test completed successfully');
    } catch (error) {
      console.error('Retry API test failed:', error);
    } finally {
      server.close(() => {
        console.log('Local test API stopped');
      });
    }
  });
};

runRetryApiTest();
