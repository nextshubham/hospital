//aprimoTokenService.test.ts

type ExecuteWithRetryOptions = {
  onRetry?: (error: unknown, retryAttempt: number, delayMs: number) => void;
};

type ExecuteWithRetryFunction = <T>(
  operation: () => Promise<T>,
  options?: ExecuteWithRetryOptions
) => Promise<T>;

const executeOperation: ExecuteWithRetryFunction = async operation =>
  operation();

const mockPost = jest.fn();
const mockIsAxiosError = jest.fn();
const mockExecuteWithRetry = jest.fn(executeOperation);
const mockLoggerError = jest.fn();
const mockLoggerWarn = jest.fn();

jest.mock('axios', () => ({
  __esModule: true,
  default: {
    post: mockPost,
    isAxiosError: mockIsAxiosError,
  },
  post: mockPost,
  isAxiosError: mockIsAxiosError,
}));

jest.mock('../../config/env', () => ({
  __esModule: true,
  default: {
    APRIMO_TOKEN_URL: 'https://training3.dam.aprimo.com/oauth/token',
    APRIMO_SCOPE: 'api',
    APRIMO_CLIENT_ID: 'test-client-id',
    APRIMO_CLIENT_SECRET: 'test-client-secret',
  },
}));

jest.mock('../../utils/httpRetry', () => ({
  executeWithRetry: mockExecuteWithRetry,
}));

jest.mock('../../utils/logger', () => ({
  __esModule: true,
  default: {
    error: mockLoggerError,
    warn: mockLoggerWarn,
    info: jest.fn(),
    debug: jest.fn(),
    trace: jest.fn(),
  },
}));

describe('aprimoTokenService', () => {
  beforeEach(() => {
    jest.resetModules();
    jest.clearAllMocks();
    jest.restoreAllMocks();

    mockExecuteWithRetry.mockImplementation(executeOperation);
  });

  it('should retrieve Aprimo access token from token API', async () => {
    mockPost.mockResolvedValue({
      data: {
        access_token: 'test-access-token',
        expires_in: 3600,
        token_type: 'Bearer',
      },
    });

    const { getAprimoAccessToken } = await import(
      '../../services/aprimoTokenService'
    );

    const result = await getAprimoAccessToken();

    expect(result).toBe('test-access-token');

    expect(mockExecuteWithRetry).toHaveBeenCalledTimes(1);
    expect(mockPost).toHaveBeenCalledTimes(1);

    expect(mockPost).toHaveBeenCalledWith(
      'https://training3.dam.aprimo.com/oauth/token',
      expect.stringContaining('grant_type=client_credentials'),
      expect.objectContaining({
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
        },
        timeout: 3000,
        httpsAgent: expect.any(Object),
      })
    );
  });

  it('should send required OAuth request body parameters', async () => {
    mockPost.mockResolvedValue({
      data: {
        access_token: 'test-access-token',
        expires_in: 3600,
        token_type: 'Bearer',
      },
    });

    const { getAprimoAccessToken } = await import(
      '../../services/aprimoTokenService'
    );

    await getAprimoAccessToken();

    const requestBody = mockPost.mock.calls[0][1] as string;

    expect(requestBody).toContain('grant_type=client_credentials');
    expect(requestBody).toContain('scope=api');
    expect(requestBody).toContain('client_id=test-client-id');
    expect(requestBody).toContain('client_secret=test-client-secret');
  });

  it('should return cached token when cached token is not expired', async () => {
    jest.spyOn(Date, 'now').mockReturnValue(1000);

    mockPost.mockResolvedValue({
      data: {
        access_token: 'cached-access-token',
        expires_in: 3600,
        token_type: 'Bearer',
      },
    });

    const { getAprimoAccessToken } = await import(
      '../../services/aprimoTokenService'
    );

    const firstResult = await getAprimoAccessToken();
    const secondResult = await getAprimoAccessToken();

    expect(firstResult).toBe('cached-access-token');
    expect(secondResult).toBe('cached-access-token');

    expect(mockPost).toHaveBeenCalledTimes(1);
    expect(mockExecuteWithRetry).toHaveBeenCalledTimes(1);
  });

  it('should generate new token before expiry buffer', async () => {
    const dateNowSpy = jest.spyOn(Date, 'now');

    dateNowSpy.mockReturnValue(1000);

    mockPost
      .mockResolvedValueOnce({
        data: {
          access_token: 'first-access-token',
          expires_in: 120,
          token_type: 'Bearer',
        },
      })
      .mockResolvedValueOnce({
        data: {
          access_token: 'second-access-token',
          expires_in: 120,
          token_type: 'Bearer',
        },
      });

    const { getAprimoAccessToken } = await import(
      '../../services/aprimoTokenService'
    );

    const firstResult = await getAprimoAccessToken();

    dateNowSpy.mockReturnValue(62000);

    const secondResult = await getAprimoAccessToken();

    expect(firstResult).toBe('first-access-token');
    expect(secondResult).toBe('second-access-token');

    expect(mockPost).toHaveBeenCalledTimes(2);
    expect(mockExecuteWithRetry).toHaveBeenCalledTimes(2);
  });

  it('should log retry warning when executeWithRetry retries Axios token request', async () => {
    const axiosError = {
      response: {
        status: 500,
      },
      config: {
        url: 'https://training3.dam.aprimo.com/oauth/token',
      },
    };

    mockIsAxiosError.mockReturnValue(true);

    mockExecuteWithRetry.mockImplementation(
      async <T>(
        operation: () => Promise<T>,
        options?: ExecuteWithRetryOptions
      ): Promise<T> => {
        options?.onRetry?.(axiosError, 1, 500);

        return operation();
      }
    );

    mockPost.mockResolvedValue({
      data: {
        access_token: 'test-access-token',
        expires_in: 3600,
        token_type: 'Bearer',
      },
    });

    const { getAprimoAccessToken } = await import(
      '../../services/aprimoTokenService'
    );

    await getAprimoAccessToken();

    expect(mockLoggerWarn).toHaveBeenCalledWith({
      msg: 'Retrying Aprimo token request',
      options: {
        retryAttempt: 1,
        delayMs: 500,
        status: 500,
        url: 'https://training3.dam.aprimo.com/oauth/token',
      },
    });
  });

  it('should log retry warning when executeWithRetry retries non-Axios token request error', async () => {
    const error = new Error('Temporary error');

    mockIsAxiosError.mockReturnValue(false);

    mockExecuteWithRetry.mockImplementation(
      async <T>(
        operation: () => Promise<T>,
        options?: ExecuteWithRetryOptions
      ): Promise<T> => {
        options?.onRetry?.(error, 1, 500);

        return operation();
      }
    );

    mockPost.mockResolvedValue({
      data: {
        access_token: 'test-access-token',
        expires_in: 3600,
        token_type: 'Bearer',
      },
    });

    const { getAprimoAccessToken } = await import(
      '../../services/aprimoTokenService'
    );

    await getAprimoAccessToken();

    expect(mockLoggerWarn).toHaveBeenCalledWith({
      msg: 'Retrying Aprimo token request',
      options: {
        retryAttempt: 1,
        delayMs: 500,
      },
    });
  });

  it('should log and throw error when token API fails with Axios error', async () => {
    const axiosError = {
      response: {
        status: 400,
        data: {
          error: 'invalid_client',
        },
      },
      config: {
        url: 'https://training3.dam.aprimo.com/oauth/token',
      },
    };

    mockIsAxiosError.mockReturnValue(true);
    mockExecuteWithRetry.mockRejectedValue(axiosError);

    const { getAprimoAccessToken } = await import(
      '../../services/aprimoTokenService'
    );

    await expect(getAprimoAccessToken()).rejects.toBe(axiosError);

    expect(mockLoggerError).toHaveBeenCalledWith({
      msg: 'Failed to retrieve aprimo access token',
      options: {
        status: 400,
        response: {
          error: 'invalid_client',
        },
        url: 'https://training3.dam.aprimo.com/oauth/token',
      },
    });
  });

  it('should throw error without logging when token API fails with non-Axios error', async () => {
    const error = new Error('Unexpected token error');

    mockIsAxiosError.mockReturnValue(false);
    mockExecuteWithRetry.mockRejectedValue(error);

    const { getAprimoAccessToken } = await import(
      '../../services/aprimoTokenService'
    );

    await expect(getAprimoAccessToken()).rejects.toThrow(
      'Unexpected token error'
    );

    expect(mockLoggerError).not.toHaveBeenCalled();
  });
});
